{
  "name": "netcomix",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": { "node": ">=20.9.0" },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=headless",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:regression": "playwright test --project=regression",
    "test:e2e:headed": "playwright test --project=headless --headed",
    "test:qa": "vitest run && playwright test --project=headless && playwright test --project=regression && playwright test --project=visual"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  }
}
