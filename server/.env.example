# Copy this to .env and fill in values for local API server development.
# Never commit .env to the repo.

DATABASE_URL=postgresql://user:password@localhost:5432/netcomix
ACCESS_CODE=dev

# Cloudflare R2 credentials (from R2 → Manage API tokens)
R2_BUCKET=netcomix
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<your-r2-access-key>
R2_SECRET_ACCESS_KEY=<your-r2-secret-key>
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
