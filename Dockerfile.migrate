FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir boto3 psycopg2-binary

# Copy harvester scripts
COPY harvester/migrate.py harvester/db_pg.py harvester/r2.py ./harvester/

# Copy comic manifests (library.json + issue.json files — no images)
COPY public/ ./public/

WORKDIR /app/harvester

# Railway injects DATABASE_URL, R2_BUCKET, R2_ENDPOINT_URL, R2_ACCESS_KEY_ID,
# R2_SECRET_ACCESS_KEY, R2_PUBLIC_URL automatically via service variables.
CMD ["python", "migrate.py"]
